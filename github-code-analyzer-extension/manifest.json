{
  "name": "GitHub AI Code Analyzer",
  "description": "This extension allows you to Analyze and understand any GitHub code instantly in the most simple technical terms.",
  "version": "1.0.1",
  "manifest_version": 3,

  "permissions": ["activeTab"],

  "host_permissions": [
    "*://github.com/*",
    "https://git-hub-code-analyzer.onrender.com/api/code/analyze"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://github.com/*"],
      "js": ["content.js"],
      "css": ["panel.css"],
      "run_at": "document_idle"
    }
  ]
}
